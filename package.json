  "scripts": {
    "start-db": "cd packages/postgis-vector-timescaledb && ./docker-start-local.sh",
    "---DOCS---": "",
    "docs--": "pnpm --filter docs",
    "doc": "pnpm docs-- dev",
    "---DEV---": "",
    "dev": "pnpm plugin-- dev",
    "---PLUGIN---": "",
    "plugin--": "pnpm --filter @b3nab/payload-hypervalue",
    "test": "pnpm plugin-- test",
    "test:int": "pnpm plugin-- test:int",
    "test:coverage": "pnpm plugin-- test:coverage",
    "build": "pnpm plugin-- build",
    "bump": "pnpm plugin-- bump",
    "pub": "pnpm publish --filter @b3nab/payload-hypervalue",
    "pub:local": "pnpm plugin-- publish:local",
    "ye": "pnpm test && pnpm build && pnpm bump && pnpm pub",
    "yeah": "pnpm test && pnpm build && pnpm bump && pnpm pub --no-git-checks",
    "yolo": "pnpm build && pnpm bump && pnpm pub --no-git-checks"
  },
  "packageManager": "pnpm@10.17.1"
}